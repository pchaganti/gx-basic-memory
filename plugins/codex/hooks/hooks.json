{
  "description": "Basic Memory for Codex hooks - orient from the graph on session start and checkpoint before compaction.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|compact",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --quiet --script \"${PLUGIN_ROOT}/hooks/session_start.py\"",
            "statusMessage": "Loading Basic Memory context",
            "timeout": 30
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "manual|auto",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --quiet --script \"${PLUGIN_ROOT}/hooks/pre_compact.py\"",
            "statusMessage": "Checkpointing Codex work to Basic Memory",
            "timeout": 60
          }
        ]
      }
    ]
  }
}
